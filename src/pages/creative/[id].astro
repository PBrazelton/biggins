---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import { resolveImage } from '../../lib/images';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map((e) => ({ params: { id: e.id }, props: { essay: e.data } }));
}

const { essay } = Astro.props;
const img = resolveImage(essay.image);
// Essay bodies aren't written yet (essays[].body points at markdown to be
// authored — CONTENT-MODEL.md §6). Until then we show the lead-in.
---
<Base title={`${essay.title} — Amelie Brazelton`} description={essay.excerpt}>
  <main>
  <section class="creative fullbleed">
    <div class="inner" style="max-width:760px">
      <p class="more"><a href="/creative/">← Back to the notebook</a></p>
      <div class="kicker">{essay.category} · {essay.period}</div>
      <h2>{essay.title}</h2>
      {img && (
        <figure style="margin:28px 0">
          <Image src={img} alt={essay.title} width={1200} quality={80} format="webp" style="width:100%;height:auto;border:1px solid var(--rule)" />
        </figure>
      )}
      <p class="intro">{essay.excerpt}</p>
      <p class="intro" style="color:var(--muted)"><em>The full essay is on its way — check back soon.</em></p>
    </div>
  </section>
  </main>
</Base>
