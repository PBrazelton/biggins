---
import PageLayout from '../../layouts/PageLayout.astro';
import EssayCard from '../../components/EssayCard.astro';
import '../../styles/page-notebook.css';
import { fetchCreative } from '../../lib/queries';

const { essays } = await fetchCreative();
---
<PageLayout title="The notebook — Amelie Brazelton" description="Personal essays and literary nonfiction by Amelie Brazelton.">
  <header class="page-head nb-head">
    <div>
      <div class="eyebrow">§ 03 — Creative Nonfiction &amp; Personal</div>
      <h1>The notebook<span class="serifit">— essays, in a quieter voice.</span></h1>
    </div>
    <p class="lede">Where the reporting ends and the reflecting begins. Personal essays and literary nonfiction, entered through the image that started each one. Tap a frame to read.</p>
  </header>

  <div class="snaps">
    {essays.map((essay: any) => <EssayCard essay={essay} />)}
  </div>
</PageLayout>
