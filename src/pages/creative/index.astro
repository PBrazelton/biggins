---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import EssayCard from '../../components/EssayCard.astro';
import sections from '../../data/sections.json';

const essays = (await getCollection('essays')).map((e) => e.data);
---
<Base title="Creative — Amelie Brazelton">
  <main>
  <section class="creative fullbleed">
    <div class="inner">
      <div class="kicker">{sections.creative.num}</div>
      <h2>{sections.creative.title}<span class="serifit">{sections.creative.subtitle}</span></h2>
      <p class="intro">{sections.creative.intro}</p>
      <div class="snaps">
        {essays.map((essay) => <EssayCard essay={essay} />)}
      </div>
    </div>
  </section>
  </main>
</Base>
