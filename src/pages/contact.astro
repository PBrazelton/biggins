---
import Base from '../layouts/Base.astro';
import Emphasis from '../components/Emphasis.astro';
import { imageUrl } from '../lib/sanity';
import { fetchContact, fetchSite } from '../lib/queries';

const [contact, site] = await Promise.all([fetchContact(), fetchSite()]);
const headshot = imageUrl(contact.headshot, 520);
---
<Base title="Contact — Amelie Brazelton" description={contact.pitch} showFooter={false}>
  <main>
  <footer id="contact" class="fullbleed">
    <div class="wrap">
      <div class="contact-lead">
        <figure class="contact-headshot">
          {headshot && <img src={headshot} alt={site.name} loading="lazy" />}
        </figure>
        <div class="contact-intro">
          <h3><Emphasis text={contact.heading} emphasis={contact.emphasis} /></h3>
          <p class="pitch">{contact.pitch}</p>
        </div>
      </div>
      <div>
        <div class="col-label">Email</div>
        <ul>
          <li><a href={`mailto:${contact.email}`}>{contact.email}</a></li>
        </ul>
        <div class="col-label" style="margin-top:24px">Press kit</div>
        <ul>
          <li><a href={contact.pressKit.url}>{contact.pressKit.label}</a></li>
        </ul>
      </div>
      <div>
        <div class="col-label">Elsewhere</div>
        <ul>
          {contact.elsewhere.map((link) => (
            <li><a href={link.url} target="_blank" rel="noopener">{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <div class="col-label">On file</div>
        <ul>
          {contact.onFile.map((link) => (
            <li><a href={link.url}>{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div class="colophon">
        {site.colophon.map((line) => <span>{line}</span>)}
      </div>
    </div>
  </footer>
  </main>
</Base>
