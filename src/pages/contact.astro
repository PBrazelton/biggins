---
import PageLayout from '../layouts/PageLayout.astro';
import Emphasis from '../components/Emphasis.astro';
import { imageUrl } from '../lib/sanity';
import { fetchContact } from '../lib/queries';
import '../styles/page-contact.css';

const contact = await fetchContact();
const portrait = imageUrl(contact.headshot, 900);
---
<PageLayout title="Contact — Amelie Brazelton" description={contact.pitch}>
  <header class="contact-hero">
    <div>
      <div class="eyebrow">Contact · Say hello</div>
      <h1><Emphasis text={contact.heading} emphasis={contact.emphasis} /></h1>
      <p class="pitch">{contact.pitch}</p>
      <div class="contact-actions">
        {(contact.elsewhere ?? []).map((l: any) => (
          <a class="sbtn" href={l.url} target="_blank" rel="noopener">{l.label} ↗</a>
        ))}
      </div>
    </div>
    <figure class="contact-portrait" style={portrait ? `background-image:url('${portrait}')` : undefined}></figure>
  </header>

  <div class="email-row">
    <a class="big" href={`mailto:${contact.email}`}>{contact.email}</a>
    <div class="where">
      <span class="avail">Available for assignment</span><br />
      Minneapolis, MN · EN · PT
    </div>
  </div>

  <div class="resume-row">
    <div>
      <div class="col-label">Résumé</div>
      <p class="rdesc">A one-page PDF — experience, bylines, and education.</p>
    </div>
    <a class="resume-dl" href={contact.pressKit?.url} download>Download résumé ↓</a>
  </div>

  <div style="height:56px"></div>
</PageLayout>
