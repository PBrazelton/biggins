---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Emphasis from '../../components/Emphasis.astro';
import ClipCard from '../../components/ClipCard.astro';
import DocRow from '../../components/DocRow.astro';
import sections from '../../data/sections.json';

const clips = (await getCollection('clips')).map((e) => e.data);
const documents = (await getCollection('documents')).map((e) => e.data);
---
<Base title="Writing — Amelie Brazelton">
  <main>
    <section id="writing">
      <div class="section-head">
        <div class="num">{sections.writing.num}</div>
        <h2><Emphasis text={sections.writing.title} emphasis={sections.writing.emphasis} /></h2>
      </div>
      <div class="clips">
        {clips.map((clip) => <ClipCard clip={clip} />)}
      </div>

      <!-- Academic & Science -->
      <div class="subhead">
        <div class="num">{sections.research.num}</div>
        <h3><Emphasis text={sections.research.title} emphasis={sections.research.emphasis} /></h3>
      </div>
      <div class="aclist">
        {documents.map((doc) => <DocRow doc={doc} />)}
      </div>
    </section>
  </main>
</Base>
