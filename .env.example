# Copy to .env (git-ignored) and fill in.

# Public — used by the Astro front-end at build to read content from Sanity.
SANITY_PROJECT_ID=your_project_id
SANITY_DATASET=production

# Secret — used ONLY by scripts/migrate-to-sanity.mjs (one-time content import).
# Create at sanity.io/manage → API → Tokens → Editor. Never commit this.
SANITY_WRITE_TOKEN=your_editor_token
